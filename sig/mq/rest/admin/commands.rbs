module MQ
  module REST
    module Admin
      # Type aliases for command method signatures.
      type request_params = Hash[String, untyped]?
      type response_params = Array[String]?
      type object_hash = Hash[String, untyped]

      module Commands
        private

        def mqsc_command: (
          command: String,
          mqsc_qualifier: String,
          name: String?,
          request_parameters: Hash[String, untyped]?,
          response_parameters: Array[String]?,
          ?where: String?
        ) -> Array[Hash[String, untyped]]

        public

        # --- Singleton display commands (return single object or nil) ---

        def display_qmgr: (?request_parameters: request_params, ?response_parameters: response_params) -> object_hash?
        def display_qmstatus: (?request_parameters: request_params, ?response_parameters: response_params) -> object_hash?
        def display_cmdserv: (?request_parameters: request_params, ?response_parameters: response_params) -> object_hash?

        # --- Collection display commands (positional name, return array) ---

        def display_apstatus: (String name, ?request_parameters: request_params, ?response_parameters: response_params, ?where: String?) -> Array[object_hash]
        def display_archive: (String name, ?request_parameters: request_params, ?response_parameters: response_params, ?where: String?) -> Array[object_hash]
